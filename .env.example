# Supabase (Projekt in der Region Central EU / Frankfurt — DSGVO!)
# Werte aus dem Supabase-Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Nur server-seitig (NIE im Client, NIE committen). Für Schüler:innen-Operations,
# die RLS umgehen müssen. Aus dem Dashboard: secret / service_role key.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Signier-Geheimnis für Schüler:innen-Session-Cookies (jose). Server-only.
# Erzeugen mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=einen-zufaelligen-32-byte-hex-wert-einsetzen

# Pexels API-Key für den Heft-Bild-Picker (Phase H2). Server-only — Anfragen
# laufen über lib/pexels.ts mit In-Memory-Cache, der Key landet nie im
# Client-Bundle. Kostenlos auf https://www.pexels.com/api/ — 200 Requests/h
# reichen für eine Schul-Klasse locker.
PEXELS_API_KEY=dein-pexels-api-key
