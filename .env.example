# Supabase (Projekt in der Region Central EU / Frankfurt — DSGVO!)
# Werte aus dem Supabase-Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Nur server-seitig (NIE im Client, NIE committen). Für Schüler:innen-Operations,
# die RLS umgehen müssen. Aus dem Dashboard: secret / service_role key.
# SUPABASE_SECRET_KEY=sb_secret_xxx
